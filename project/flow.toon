# contract/flow | 412 func | 12 pipelines | 6 hub-types | 2026-03-05

PIPELINES[12] (Analysis:2, Core:1, Export:1, IO:4, NLP:2, Unknown:2):
  Reclapp-contracts [IO]: ? → str
              → main()                                  CC=1    pure ▶
              → cli(args:Optional[list[str]]) → int     CC=13   pure
              → cmd_validate(args:argparse.Namespace) → int CC=7    IO
              → parse_contract_markdown(content:str) → ContractMarkdown CC=1    pure
              → _parse_entities_section(body:str) → list[MarkdownEntityDefinition] CC=5    mutation
