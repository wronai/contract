    LiveUpdate: __init__(1),update(1),clear(0),__enter__(0),__exit__(0)  # Live-updating display that refreshes...
    StatusIndicator: __init__(0),start(1),done(1),fail(1),skip(1)  # A status indicator that shows step-by...
    _is_tty()->bool
    _clear_line()->None
    _write_inline(text:str)->None
    progress(iterable:Iterable[T];label:str='';total:Optional[int]=None)->Generator[T, None, None]
    spinner(message:str='Loading...';style:str='dots')->Generator[Spinner, None, None]
    live(initial:str='')->Generator[LiveUpdate, None, None]
