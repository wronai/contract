    loadEnvFromFile()
    loadContract(contractPath)
    cmdGenerate(contractPath;options)
    startDocker(outputDir)
    cmdDev(contractPath;options)
    cmdRun(contractPath;options)
    cmdTest(contractPath;options)
    cmdDeploy(contractPath;options)
  contracts/types.ts:
    e: NegotiationProtocol,FeedbackSource,FieldType,LearningConfig,Permission,EntityEvent,createWorkflow,Enforcement
    AgentContractBuilder: constructor(2),description(1),author(1),addEntity(1),workflow(1)
    createEntity(config: {   name: string;   description?: string;   fields: Field[];   causalInfluences?: CausalInfluence[];   interventions?: Intervention[]; })->Entity
    createWorkflow(config: {   name: string;   steps: WorkflowStep[];   safety?: Partial<SafetyRails>;   schedule?: string; })->Workflow
    createVerification(config: {   metrics: VerificationMetric[];   thresholds?: Partial<VerificationThresholds>;   learningConfig?: Partial<LearningConfig>; })->Verification
    defineContract(name: string;version?)->AgentContractBuilder
